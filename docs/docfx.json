{
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "favicon.ico",
          "logo.svg"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern",
      "my-template"
    ],
    "globalMetadata": {
      "_appName": "Bonsai",
      "_appTitle": "Bonsai",
      "_enableNewTab": true,
      "_enableSearch": false,
      "_appLogoPath":"logo.svg",
      "_appFaviconPath":"favicon.ico",
      "pdf": false,
      "_appFooter": "<span>&copy; 2024 Bonsai Foundation and Contributors</span> - <span>Made with <a href=\"https://dotnet.github.io/docfx\">docfx</a></span>"
    },
    "markdownEngineName": "markdig",
    "markdownEngineProperties": {
      "markdigExtensions": [
        "attributes"
      ]
    }
  }
}